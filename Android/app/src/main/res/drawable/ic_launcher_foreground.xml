<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <!-- El logo se coloca en el centro del viewport de 108x108.
         El "safe zone" para iconos adaptativos es de unos 66dp o 72dp.
         Usamos un grupo con escala para reducir el tamaño del logo. -->
    <group
        android:pivotX="54"
        android:pivotY="54"
        android:scaleX="0.65"
        android:scaleY="0.65">
        <path
            android:pathData="M0,0h108v108h-108z"
            android:fillColor="#00000000" />
        <!-- Aquí usamos un truco: como no puedo redimensionar el PNG directamente con código XML de vector fácilmente
             para que sea dinámico, la mejor opción es usar un InsetDrawable.
             Pero para mantener la estructura de Adaptive Icon, voy a crear un nuevo recurso drawable. -->
    </group>
</vector>